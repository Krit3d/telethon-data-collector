# Database variables (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tg_parser

POSTS_LIMIT=10
CONCURRENCY=10
LOG_LEVEL=INFO
NETWORK_RETRIES=5
NETWORK_RETRY_BASE_DELAY_S=1.0

# Postgres URL for the application
DB_URL=postgresql+asyncpg://postgres:postgres@db:5432/tg_parser

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=telegram_posts
QDRANT_BATCH_SIZE=100
QDRANT_TIMEOUT=30.0

# Crawler delays between Telegram API calls
CRAWLER_DELAY_MIN=45
CRAWLER_DELAY_MAX=120

# Telegram API Credentials (get on my.telegram.org)
API_ID=your_id
API_HASH=your_hash

# Channels to handle (comma-separated usernames or links).
# If CHANNELS is set and not empty, it takes priority over channels.txt.
CHANNELS=durov,https://t.me/telegram,@somechannel

# Proxy settings (optional)
# PROXY_URL=socks5://user:pass@ip:port
# PROXY_URL=mtproxy://secret@ip:port
# PROXY_URL=mtproxy://ip:port?secret=..."
PROXY_URL=